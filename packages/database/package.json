{
  "name": "@firstroad/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "type": "tsc --noEmit --project tsconfig.json",
    "db:generate": "prisma generate",
    "db:migrate": "bun --env-file .env prisma migrate dev",
    "db:deploy": "bun --env-file .env prisma migrate deploy",
    "clear:attachments": "bun --bun --env-file .env prisma/scripts/clear-attachments.ts",
    "clear:attachments:local": "bun --bun --env-file .env.local prisma/scripts/clear-attachments.ts",
    "clear:non-auth": "bun prisma/scripts/clear-non-auth-tables.ts",
    "seed:members": "bun prisma/scripts/seed-org-members.ts",
    "postinstall": "prisma generate",
    "db:migrate:local": "bun --env-file .env.local prisma migrate dev",
    "db:push": "bun --env-file .env prisma db push",
    "db:push:local": "bun --env-file .env.local prisma db push",
    "db:seed": "bun --env-file .env prisma db seed",
    "db:seed:local": "bun --env-file .env.local prisma db seed",
    "db:restore:local": "bun --env-file .env.local pg_restore -v -d \"$DATABASE_URL\" --clean --if-exists neon-data-only.dump",
    "seed:comment-permissions": "bun --env-file .env prisma/scripts/seed-member-permissions-comment.ts",
    "seed:comment-permissions:local": "bun --env-file .env.local prisma/scripts/seed-member-permissions-comment.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@prisma/adapter-neon": "^7.4.2",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "elysia": "^1.4.27",
    "prisma": "^7.4.2",
    "prismabox": "^1.1.26"
  },
  "exports": {
    ".": "./src/index.ts",
    "./client-types": "./src/client-types.ts",
    "./member-permissions": "./src/member-permissions.ts"
  }
}
