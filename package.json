{
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@typescript/native-preview": "7.0.0-dev.20260406.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "turbo": "^2.9.6",
    "typescript": "^6.0.3",
    "ultracite": "7.6.0"
  },
  "name": "firstroad",
  "scripts": {
    "dev": "turbo run dev --filter=@firstroad/web",
    "dev:email": "turbo run dev --filter=@firstroad/emails",
    "build": "turbo run build --filter='!@firstroad/emails'",
    "start": "turbo run start",
    "postinstall": "turbo run postinstall",
    "dev:inspect": "turbo run dev:inspect",
    "next:upgrade": "turbo run next:upgrade",
    "next:analyze": "turbo run next:analyze",
    "build:debug": "turbo run build:debug",
    "build:debug:prerender": "turbo run build:debug:prerender",
    "type": "turbo run type",
    "typegen": "turbo run typegen",
    "reset:tickets": "turbo run reset:tickets --filter=@firstroad/web",
    "clear:non-auth": "turbo run clear:non-auth --filter=@firstroad/db",
    "clear:attachments": "turbo run clear:attachments --filter=@firstroad/db",
    "seed:members": "turbo run seed:members --filter=@firstroad/db",
    "build:email": "turbo run build:email",
    "export:email": "turbo run export:email",
    "resend:list": "turbo run resend:list --filter=@firstroad/web",
    "resend:download": "turbo run resend:download --filter=@firstroad/web",
    "prepare": "husky",
    "deploy:prod": "cd apps/web && vercel deploy --prod",
    "ultracite:upgrade": "bun x ultracite@latest init --pm bun --linter biome --agents cursor-cli --editors vscode --hooks cursor --frameworks next --quiet",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "doctor": "ultracite doctor"
  },
  "type": "module",
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "private": true,
  "packageManager": "bun@1.3.12",
  "overrides": {
    "hono": ">=4.12.12",
    "uuid": ">=14.0.0",
    "undici": ">=7.18.2",
    "next": ">=16.2.4",
    "@modelcontextprotocol/sdk": ">=1.25.2",
    "defu": ">6.1.4",
    "@hono/node-server": ">=1.19.13",
    "protobufjs": ">=8.0.1",
    "postcss": ">=8.5.10"
  }
}
